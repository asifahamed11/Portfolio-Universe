---
// PortfolioCard.astro
interface Props {
  name: string;
  url: string;
  screenshot: string | null;
  summary?: string;
  role?: string;
  tech_stack?: string[];
  available_for_hire?: boolean;
  base_likes: number;
}

const { name, url, screenshot, summary, role, tech_stack, available_for_hire, base_likes } = Astro.props;

// Fallback to a microlink generated screenshot if missing
const screenshotUrl = screenshot || `https://api.microlink.io/?url=${encodeURIComponent(url)}&screenshot=true&meta=false&embed=screenshot.url`;
---

<a href={url} target="_blank" rel="noopener noreferrer" class="group relative flex flex-col bg-slate-900 border border-slate-800 rounded-2xl hover:border-blue-500/50 hover:shadow-[0_8px_30px_-10px_rgba(59,130,246,0.3)] transition-[transform,box-shadow,border-color] duration-300 ease-out transform-gpu will-change-transform hover:-translate-y-1 hover:z-40 [backface-visibility:hidden]">
  
  <!-- Image Section -->
  <div class="relative aspect-[16/10] w-full overflow-hidden bg-slate-950 rounded-t-2xl [transform:translateZ(0)]">
    <!-- Image -->
    <img 
      src={screenshotUrl} 
      alt={`Screenshot of ${name}'s portfolio`}
      loading="lazy"
      class="w-full h-full object-cover object-top opacity-80 group-hover:opacity-100 group-hover:scale-105 transition-[opacity,transform] duration-300 ease-out transform-gpu will-change-transform [backface-visibility:hidden]"
      onerror="this.onerror=null; this.src='https://images.unsplash.com/photo-1517694712202-14dd9538aa97?q=80&w=600&auto=format&fit=crop';"
    />
    
    <!-- Gradient overlay -->
    <div class="absolute inset-0 z-10 bg-gradient-to-t from-slate-900 via-transparent to-transparent opacity-60"></div>

    <!-- Tags (Top Left) -->
    <div class="absolute top-3 left-3 z-20 flex flex-wrap gap-1.5 pointer-events-none">
      {available_for_hire && (
        <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-md bg-green-500/90 backdrop-blur-md text-white text-[10px] font-bold uppercase tracking-wider shadow-lg">
          <span class="w-1 h-1 rounded-full bg-white animate-pulse"></span>
          Hire Me
        </span>
      )}
      {typeof role === 'string' && role !== "Unknown" && (
        <span class="inline-block px-2 py-0.5 rounded-md bg-black/60 backdrop-blur-md border border-white/10 text-gray-200 text-[10px] font-medium tracking-wide">
          {role.split(' ')[0]}
        </span>
      )}
    </div>

    <!-- Interactive Heart / Bookmark / Like (Top Right) -->
    <button 
      class="bookmark-btn absolute top-3 right-3 z-30 flex items-center gap-1.5 px-2.5 py-1.5 rounded-full bg-slate-900/60 backdrop-blur-md border border-white/10 text-slate-300 hover:text-red-400 hover:bg-slate-800/80 hover:border-red-500/30 transition-all duration-300 group/btn shadow-[0_0_15px_-3px_rgba(0,0,0,0.5)]"
      data-url={url}
      data-base-likes={base_likes}
      aria-label="Bookmark and Like"
      onclick="event.preventDefault(); window.toggleBookmark(this, this.dataset.url)"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="heart-icon transition-transform group-hover/btn:scale-110 active:scale-90 drop-shadow-md"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
      <span class="text-xs font-bold tracking-wide like-count drop-shadow-md">{base_likes}</span>
    </button>
  </div>
  
  <!-- Content Section -->
  <div class="relative z-10 p-5 flex flex-col flex-grow bg-slate-900 rounded-b-2xl">
    <div class="flex justify-between items-start mb-2">
      <h3 class="text-xl font-bold text-slate-100 line-clamp-1 group-hover:text-blue-400 transition-colors duration-300 pr-2">
        {name}
      </h3>
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-slate-500 group-hover:text-blue-400 transition-colors opacity-0 group-hover:opacity-100 transform -translate-x-2 group-hover:translate-x-0 duration-300 shrink-0 mt-1"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
    </div>
    
    <!-- Animated Divider -->
    <div class="w-8 h-1 bg-slate-700 rounded-full mb-4 group-hover:w-16 group-hover:bg-blue-500 transition-all duration-300 ease-out"></div>
    


    <!-- Tech Stack Mini Badges -->
    {tech_stack && tech_stack.length > 0 && (
      <div class="flex flex-wrap gap-1.5 mt-auto pt-2">
        {tech_stack.slice(0, 3).map(tech => (
          <span class="px-2 py-0.5 rounded-md bg-slate-800 text-slate-400 text-[11px] font-medium border border-slate-700/50">
            {tech}
          </span>
        ))}
        {tech_stack.length > 3 && (
          <span class="px-2 py-0.5 rounded-md bg-slate-800 text-slate-500 text-[11px] font-medium border border-slate-700/50">
            +{tech_stack.length - 3}
          </span>
        )}
      </div>
    )}
  </div>
</a>


