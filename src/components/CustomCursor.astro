---
// CustomCursor.astro
---

<div id="custom-cursor" class="pointer-events-none fixed inset-0 z-[10000] hidden">
  


  <!-- Main Container -->
  <div id="cursor-main" class="absolute top-0 left-0 rounded-full flex items-center justify-center will-change-transform transition-[width,height] duration-300 ease-[cubic-bezier(0.16,1,0.3,1)] z-[10000]" style="width: 48px; height: 48px; transform: translate(-50%, -50%);">
    
    <!-- Dynamic Background Glass Distortion Layer -->
    <div id="cursor-glass-layer" class="absolute inset-0 rounded-full pointer-events-none overflow-hidden transition-all duration-300 transform-gpu" 
         style="
           background: rgba(255,255,255,0.02); backdrop-filter: blur(4px) saturate(150%) brightness(1.1); -webkit-backdrop-filter: blur(4px) saturate(150%) brightness(1.1);



           transform: translateZ(0);
         ">
    </div>

    <!-- Edge Lighting Layer -->
    <div id="cursor-border-layer" class="absolute inset-0 rounded-full pointer-events-none transition-all duration-300"
         style="
           box-shadow: inset 0 0 10px rgba(255, 255, 255, 0.2), inset 2px 2px 5px rgba(255, 255, 255, 0.4), inset -2px -2px 5px rgba(0, 0, 0, 0.1), 0 4px 10px rgba(0, 0, 0, 0.2);
           border: 1px solid rgba(255,255,255,0.1);
         ">
    </div>
  </div>
  
  <!-- Clear text wrapper -->
  <div id="cursor-text-wrapper" class="absolute top-0 left-0 flex items-center justify-center will-change-transform pointer-events-none transition-[width,height] duration-300 z-[10001]" style="transform: translate(-50%, -50%); width: 48px; height: 48px;">
    <span id="cursor-text" class="text-white text-[11px] uppercase tracking-[0.2em] font-extrabold opacity-0 transition-opacity duration-300 ml-[2px]" style="text-shadow: 0 2px 10px rgba(0,0,0,1);"></span>
  </div>
</div>

<style is:global>
  @media (pointer: fine) {
    html.custom-cursor-active,
    html.custom-cursor-active * {
      cursor: none !important;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    if (!window.matchMedia('(pointer: fine)').matches) return;

    document.documentElement.classList.add('custom-cursor-active');
    
    const cursorContainer = document.getElementById('custom-cursor');
    const cursorMain = document.getElementById('cursor-main');
    const cursorTextWrapper = document.getElementById('cursor-text-wrapper');
    const cursorText = document.getElementById('cursor-text');
    const borderLayer = document.getElementById('cursor-border-layer');
    const glassLayer = document.getElementById('cursor-glass-layer');
    
    if (cursorContainer) cursorContainer.classList.remove('hidden');

    let mouseX = window.innerWidth / 2;
    let mouseY = window.innerHeight / 2;
    let cursorX = mouseX;
    let cursorY = mouseY;
    let isHoveringCard = false;
    
    document.addEventListener('mousemove', (e) => {
      mouseX = e.clientX;
      mouseY = e.clientY;
    });

    // PERF-5 fix: don't read offsetWidth/offsetHeight every animation frame (forces a
    // layout reflow at 60fps). Cache the half-size and update it only when the cursor
    // actually resizes, via ResizeObserver.
    let halfW = 24;
    let halfH = 24;
    if (cursorMain && 'ResizeObserver' in window) {
      const sizeObserver = new ResizeObserver((entries) => {
        const r = entries[0].contentRect;
        halfW = r.width / 2;
        halfH = r.height / 2;
      });
      sizeObserver.observe(cursorMain);
    }

    const render = () => {
      cursorX += (mouseX - cursorX) * 0.25; 
      cursorY += (mouseY - cursorY) * 0.25;
      
      const transformStr = `translate3d(${cursorX - halfW}px, ${cursorY - halfH}px, 0) scale(${cursorMain?.dataset.scale || 1})`;
      
      if (cursorMain) cursorMain.style.transform = transformStr;
      if (cursorTextWrapper) cursorTextWrapper.style.transform = transformStr;
      
      requestAnimationFrame(render);
    };
    requestAnimationFrame(render);

    const attachHoverEffects = () => {
      // 1. Portfolio Cards
      const cards = document.querySelectorAll('a[target="_blank"]');
      cards.forEach((el) => {
        if (el.dataset.cursorBoundCard) return;
        el.dataset.cursorBoundCard = 'true';

        el.addEventListener('mouseenter', () => {
          isHoveringCard = true;
          if (cursorMain && cursorTextWrapper && cursorText && borderLayer) {
            cursorMain.style.width = '80px';
            cursorMain.style.height = '80px';
            
            cursorTextWrapper.style.width = '80px';
            cursorTextWrapper.style.height = '80px';
            cursorText.textContent = 'OPEN';
            cursorText.style.opacity = '1';
            
            borderLayer.style.boxShadow = 'inset 0 0 15px rgba(255, 255, 255, 0.1), inset 2px 2px 8px rgba(255, 255, 255, 0.5), inset -2px -2px 8px rgba(0, 0, 0, 0.15), 0 8px 20px rgba(0, 0, 0, 0.3)';
            borderLayer.style.border = '1px solid rgba(255,255,255,0.15)';
            borderLayer.style.background = 'transparent';
            if(glassLayer) {
                glassLayer.style.background = 'transparent';


            }
          }
        });
        el.addEventListener('mouseleave', () => {
          isHoveringCard = false;
          if (cursorMain && cursorTextWrapper && cursorText && borderLayer) {
            cursorMain.style.width = '48px';
            cursorMain.style.height = '48px';
            
            cursorTextWrapper.style.width = '48px';
            cursorTextWrapper.style.height = '48px';
            cursorText.style.opacity = '0';
            
            borderLayer.style.boxShadow = 'inset 0 0 10px rgba(255, 255, 255, 0.2), inset 2px 2px 5px rgba(255, 255, 255, 0.4), inset -2px -2px 5px rgba(0, 0, 0, 0.1), 0 4px 10px rgba(0, 0, 0, 0.2)';
            borderLayer.style.border = '1px solid rgba(255,255,255,0.1)';
            borderLayer.style.background = 'transparent';
            if(glassLayer) {
                glassLayer.style.background = 'transparent';


            }
          }
        });
      });

      // 2. Normal Buttons & Links
      const clickables = document.querySelectorAll('button:not(.bookmark-btn), .filter-btn, .cursor-pointer, a:not([target="_blank"])');
      clickables.forEach((el) => {
        if (el.dataset.cursorBoundBtn) return;
        el.dataset.cursorBoundBtn = 'true';

        el.addEventListener('mouseenter', () => {
          if (cursorMain && cursorTextWrapper && !isHoveringCard && borderLayer) {
            cursorMain.style.width = '60px';
            cursorMain.style.height = '60px';
            cursorTextWrapper.style.width = '60px';
            cursorTextWrapper.style.height = '60px';
            if (cursorText) cursorText.style.opacity = '0'; 
            
            borderLayer.style.boxShadow = 'inset 0 0 12px rgba(244, 63, 94, 0.2), inset 2px 2px 6px rgba(244, 63, 94, 0.5), inset -2px -2px 6px rgba(0, 0, 0, 0.1), 0 6px 16px rgba(0, 0, 0, 0.2)';
            borderLayer.style.border = '1px solid rgba(244, 63, 94, 0.3)';
            borderLayer.style.background = 'rgba(244,63,94,0.05)';
            if(glassLayer) {


            }
          }
        });
        el.addEventListener('mouseleave', () => {
          if (cursorMain && cursorTextWrapper && !isHoveringCard && borderLayer) {
            cursorMain.style.width = '48px';
            cursorMain.style.height = '48px';
            cursorTextWrapper.style.width = '48px';
            cursorTextWrapper.style.height = '48px';
            
            borderLayer.style.boxShadow = 'inset 2px 2px 8px rgba(255, 255, 255, 0.6), inset -4px -4px 12px rgba(0, 0, 0, 0.3), 0 8px 16px rgba(0, 0, 0, 0.3)';
            borderLayer.style.background = 'transparent';
          }
        });
      });

      // 3. Like Buttons
      const likeBtns = document.querySelectorAll('.bookmark-btn');
      likeBtns.forEach((el) => {
        if (el.dataset.cursorBoundLike) return;
        el.dataset.cursorBoundLike = 'true';

        el.addEventListener('mouseenter', () => {
          if (cursorMain && cursorTextWrapper && borderLayer) {
            cursorMain.style.width = '12px';
            cursorMain.style.height = '12px';
            cursorTextWrapper.style.width = '12px';
            cursorTextWrapper.style.height = '12px';
            if (cursorText) cursorText.style.opacity = '0'; 
            
            borderLayer.style.boxShadow = 'inset 0 0 8px rgba(244, 63, 94, 0.4), inset 2px 2px 4px rgba(244, 63, 94, 0.6), inset -2px -2px 4px rgba(0, 0, 0, 0.2), 0 4px 10px rgba(0, 0, 0, 0.2)';
            borderLayer.style.border = '1px solid rgba(244, 63, 94, 0.5)';
            borderLayer.style.background = 'transparent';
            if(glassLayer) {


            }
          }
        });
        el.addEventListener('mouseleave', () => {
          if (!cursorMain || !cursorTextWrapper || !borderLayer) return;
          
          if (isHoveringCard) {
            // Revert back to OPEN state
            cursorMain.style.width = '80px';
            cursorMain.style.height = '80px';
            cursorTextWrapper.style.width = '80px';
            cursorTextWrapper.style.height = '80px';
            if (cursorText) {
                cursorText.textContent = 'OPEN';
                cursorText.style.opacity = '1';
            }
            borderLayer.style.boxShadow = 'inset 0 0 15px rgba(255, 255, 255, 0.1), inset 2px 2px 8px rgba(255, 255, 255, 0.5), inset -2px -2px 8px rgba(0, 0, 0, 0.15), 0 8px 20px rgba(0, 0, 0, 0.3)';
            borderLayer.style.border = '1px solid rgba(255,255,255,0.15)';
            borderLayer.style.background = 'transparent';
          } else {
            // Revert to normal state
            cursorMain.style.width = '48px';
            cursorMain.style.height = '48px';
            cursorTextWrapper.style.width = '48px';
            cursorTextWrapper.style.height = '48px';
            
            borderLayer.style.boxShadow = 'inset 2px 2px 8px rgba(255, 255, 255, 0.6), inset -4px -4px 12px rgba(0, 0, 0, 0.3), 0 8px 16px rgba(0, 0, 0, 0.3)';
            borderLayer.style.background = 'transparent';
          }
        });
      });
    };

    attachHoverEffects();
    // PERF-3: Debounce MutationObserver to avoid excessive DOM queries during infinite scroll
    let cursorMutationTimeout;
    const observer = new MutationObserver(() => {
      clearTimeout(cursorMutationTimeout);
      cursorMutationTimeout = setTimeout(attachHoverEffects, 200);
    });
    observer.observe(document.body, { childList: true, subtree: true });
    
    // Click effects
    document.addEventListener('mousedown', () => {
      if (cursorMain) cursorMain.dataset.scale = '0.8';
      if (cursorTextWrapper) cursorTextWrapper.dataset.scale = '0.8';
    });
    
    document.addEventListener('mouseup', () => {
      if (cursorMain) cursorMain.dataset.scale = '1';
      if (cursorTextWrapper) cursorTextWrapper.dataset.scale = '1';
    });
  });
</script>
