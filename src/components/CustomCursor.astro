---
// CustomCursor.astro
---

<div id="custom-cursor" class="pointer-events-none fixed inset-0 z-[10000] hidden">
  <!-- Clean Frosted Glass Cursor -->
  <div id="cursor-main" class="absolute top-0 left-0 rounded-full flex items-center justify-center will-change-transform transition-[width,height,background-color,border-color,backdrop-filter] duration-300 ease-[cubic-bezier(0.16,1,0.3,1)] overflow-hidden" 
       style="
         width: 24px; 
         height: 24px; 
         transform: translate(-50%, -50%); 
         background: rgba(255,255,255,0.05); 
         backdrop-filter: blur(8px);
         -webkit-backdrop-filter: blur(8px);
         border: 1px solid rgba(255,255,255,0.15);
         box-shadow: 0 4px 15px rgba(0,0,0,0.1), inset 0 0 10px rgba(255,255,255,0.05);
       ">
  </div>
  
  <!-- Clear text wrapper -->
  <div id="cursor-text-wrapper" class="absolute top-0 left-0 flex items-center justify-center will-change-transform pointer-events-none transition-[width,height] duration-300" style="transform: translate(-50%, -50%); width: 24px; height: 24px;">
    <span id="cursor-text" class="text-white text-[11px] uppercase tracking-[0.2em] font-extrabold opacity-0 transition-opacity duration-300 ml-[2px]" style="text-shadow: 0 2px 10px rgba(0,0,0,1);"></span>
  </div>
</div>

<style is:global>
  @media (pointer: fine) {
    html.custom-cursor-active,
    html.custom-cursor-active * {
      cursor: none !important;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    if (!window.matchMedia('(pointer: fine)').matches) return;

    document.documentElement.classList.add('custom-cursor-active');
    
    const cursorContainer = document.getElementById('custom-cursor');
    const cursorMain = document.getElementById('cursor-main');
    const cursorTextWrapper = document.getElementById('cursor-text-wrapper');
    const cursorText = document.getElementById('cursor-text');
    
    if (cursorContainer) cursorContainer.classList.remove('hidden');

    let mouseX = window.innerWidth / 2;
    let mouseY = window.innerHeight / 2;
    let cursorX = mouseX;
    let cursorY = mouseY;
    let isHoveringCard = false;
    
    document.addEventListener('mousemove', (e) => {
      mouseX = e.clientX;
      mouseY = e.clientY;
    });

    const render = () => {
      cursorX += (mouseX - cursorX) * 0.25; 
      cursorY += (mouseY - cursorY) * 0.25;
      
      const transformStr = `translate3d(calc(${cursorX}px - 50%), calc(${cursorY}px - 50%), 0) scale(${cursorMain?.dataset.scale || 1})`;
      
      if (cursorMain) cursorMain.style.transform = transformStr;
      if (cursorTextWrapper) cursorTextWrapper.style.transform = transformStr;
      
      requestAnimationFrame(render);
    };
    requestAnimationFrame(render);

    const attachHoverEffects = () => {
      // 1. Portfolio Cards
      const cards = document.querySelectorAll('a[target="_blank"]');
      cards.forEach((el) => {
        if (el.dataset.cursorBoundCard) return;
        el.dataset.cursorBoundCard = 'true';

        el.addEventListener('mouseenter', () => {
          isHoveringCard = true;
          if (cursorMain && cursorTextWrapper && cursorText) {
            // Large clean frosted glass
            cursorMain.style.width = '80px';
            cursorMain.style.height = '80px';
            cursorMain.style.background = 'rgba(255,255,255,0.08)';
            cursorMain.style.backdropFilter = 'blur(16px)';
            cursorMain.style.border = '1px solid rgba(255,255,255,0.2)';
            
            cursorTextWrapper.style.width = '80px';
            cursorTextWrapper.style.height = '80px';
            cursorText.textContent = 'OPEN';
            cursorText.style.opacity = '1';
          }
        });
        el.addEventListener('mouseleave', () => {
          isHoveringCard = false;
          if (cursorMain && cursorTextWrapper && cursorText) {
            // Reset to small glass
            cursorMain.style.width = '24px';
            cursorMain.style.height = '24px';
            cursorMain.style.background = 'rgba(255,255,255,0.05)';
            cursorMain.style.backdropFilter = 'blur(8px)';
            cursorMain.style.border = '1px solid rgba(255,255,255,0.15)';
            
            cursorTextWrapper.style.width = '24px';
            cursorTextWrapper.style.height = '24px';
            cursorText.style.opacity = '0';
          }
        });
      });

      // 2. Normal Buttons & Links
      const clickables = document.querySelectorAll('button, .filter-btn, .cursor-pointer, a:not([target="_blank"])');
      clickables.forEach((el) => {
        if (el.dataset.cursorBoundBtn) return;
        el.dataset.cursorBoundBtn = 'true';

        el.addEventListener('mouseenter', () => {
          if (cursorMain && cursorTextWrapper && !isHoveringCard) {
            // Medium glass for buttons
            cursorMain.style.width = '48px';
            cursorMain.style.height = '48px';
            cursorMain.style.background = 'rgba(244,63,94,0.05)'; // subtle rose tint
            cursorMain.style.border = '1px solid rgba(244,63,94,0.3)';
            
            cursorTextWrapper.style.width = '48px';
            cursorTextWrapper.style.height = '48px';
            if (cursorText) cursorText.style.opacity = '0'; 
          }
        });
        el.addEventListener('mouseleave', () => {
          if (cursorMain && cursorTextWrapper && !isHoveringCard) {
            // Reset to small glass
            cursorMain.style.width = '24px';
            cursorMain.style.height = '24px';
            cursorMain.style.background = 'rgba(255,255,255,0.05)';
            cursorMain.style.border = '1px solid rgba(255,255,255,0.15)';
            
            cursorTextWrapper.style.width = '24px';
            cursorTextWrapper.style.height = '24px';
          }
        });
      });
    };

    attachHoverEffects();
    const observer = new MutationObserver(() => attachHoverEffects());
    observer.observe(document.body, { childList: true, subtree: true });
    
    // Click effects
    document.addEventListener('mousedown', () => {
      if (cursorMain) cursorMain.dataset.scale = '0.8';
      if (cursorTextWrapper) cursorTextWrapper.dataset.scale = '0.8';
    });
    
    document.addEventListener('mouseup', () => {
      if (cursorMain) cursorMain.dataset.scale = '1';
      if (cursorTextWrapper) cursorTextWrapper.dataset.scale = '1';
    });
  });
</script>
