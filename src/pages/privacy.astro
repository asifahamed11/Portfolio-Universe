---
import '../styles/global.css';
import CustomCursor from '../components/CustomCursor.astro';
---

<html lang="en">
  <head>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;700;900&family=Space+Grotesk:wght@400;700;900&display=swap" rel="stylesheet">
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`\${import.meta.env.BASE_URL}favicon.svg`} />
    <meta name="viewport" content="width=device-width" />
    <title>Privacy Policy - Developer Portfolios Showcase</title>
  </head>
  <body class="bg-[#0a0a0c] text-gray-200 min-h-screen font-sans antialiased selection:bg-rose-500/30">
    <CustomCursor />
    <!-- Ambient Background Effects -->
    <div class="absolute top-0 left-0 right-0 h-[400px] z-[-1] overflow-hidden pointer-events-none">
      <div class="absolute inset-0 glass-bg [mask-image:linear-gradient(to_bottom,black_50%,transparent_100%)]" style="-webkit-mask-image: linear-gradient(to bottom, black 50%, transparent 100%);"></div>
    </div>
    <div class="fixed inset-0 z-[-2] bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-[#1a1820] via-[#0a0a0c] to-[#040405]"></div>
    
    <nav class="sticky top-4 z-40 max-w-3xl mx-4 xl:mx-auto rounded-[24px] border border-white/[0.05] bg-gray-900/40 backdrop-blur-md">
      <div class="px-4 py-4 flex items-center justify-between">
        <a href={import.meta.env.BASE_URL} class="text-white font-bold tracking-tight hover:text-blue-400 transition-colors flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
          Back to Showcase
        </a>
      </div>
    </nav>

    <main class="max-w-3xl mx-auto px-6 py-16 relative z-10">
      <div class="bg-gray-900/60 backdrop-blur-xl border border-white/10 rounded-3xl p-8 md:p-12 shadow-2xl">
        <h1 class="text-4xl md:text-5xl font-black mb-8 text-white" style="font-family: 'Space Grotesk', sans-serif;">Privacy Policy</h1>
        
        <div class="space-y-8 text-gray-300 leading-relaxed">
          <section>
            <h2 class="text-2xl font-bold text-white mb-4">1. Information We Collect</h2>
            <p>When you log in using GitHub or Google, we collect basic profile information provided by the authentication provider, such as your name, email address, and profile picture. We also track which portfolios you bookmark/like.</p>
          </section>

          <section>
            <h2 class="text-2xl font-bold text-white mb-4">2. How We Use Your Information</h2>
            <p>We use your information solely to provide the core functionality of the site, which includes saving your favorite portfolios across devices and displaying your name/avatar when you are logged in.</p>
          </section>

          <section>
            <h2 class="text-2xl font-bold text-white mb-4">3. Data Storage</h2>
            <p>Your authentication data and bookmarks are securely stored using Google Firebase. We do not sell, rent, or share your personal information with third parties.</p>
          </section>

          <section>
            <h2 class="text-2xl font-bold text-white mb-4">4. Analytics</h2>
            <p>We use standard analytics tools (like Google Analytics) to track website traffic and usage patterns. This data is aggregated and does not personally identify you.</p>
          </section>

          <section>
            <h2 class="text-2xl font-bold text-white mb-4">5. Contact Us</h2>
            <p>If you have questions about this Privacy Policy or wish to have your data removed, please contact the site administrator.</p>
          </section>
        </div>
      </div>
    </main>

    <footer class="py-8 text-center text-gray-500 text-sm">
      <p>&copy; {new Date().getFullYear()} Portfolio Universe. All rights reserved.</p>
    </footer>

    <style>
      .glass-bg {
        background: url(https://raw.githubusercontent.com/lucasromerodb/liquid-glass-effect-macos/refs/heads/main/assets/flowers.jpg) center center;
        background-size: 400px;
        opacity: 0.15;
      }
    </style>
  </body>
</html>
