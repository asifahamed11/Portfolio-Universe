---
import PortfolioCard from '../components/PortfolioCard.astro';
import LoginModal from '../components/LoginModal.astro';
import SubmitModal from '../components/SubmitModal.astro';
import CustomCursor from '../components/CustomCursor.astro';
import portfoliosData from '../data/portfolios.json';
import VariableProximityWrapper from '../components/VariableProximityWrapper.jsx';
import GlassSurface from '../components/GlassSurface.jsx';
import FluidGlassPill from '../components/FluidGlassPill.jsx';
import RotatingText from '../components/RotatingText.jsx';
import '../styles/global.css';

// Map portfolios to include baseLikes (real likes start at 0)
const portfolios = portfoliosData.map(p => ({
  ...p,
  baseLikes: 0
}));
---

<html lang="en">
  <head>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;700;900&family=Space+Grotesk:wght@400;700;900&display=swap" rel="stylesheet">
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>Developer Portfolios Showcase</title>
    <meta name="description" content="A curated directory of developer portfolios inspired by Emma Bostian's repository." />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://portfoliouniverse.com/" />
    <meta property="og:title" content="Developer Portfolios Showcase" />
    <meta property="og:description" content="A curated directory of developer portfolios inspired by Emma Bostian's repository." />
    <meta property="og:image" content="https://images.unsplash.com/photo-1517694712202-14dd9538aa97?q=80&w=1200&auto=format&fit=crop" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content="https://portfoliouniverse.com/" />
    <meta property="twitter:title" content="Developer Portfolios Showcase" />
    <meta property="twitter:description" content="A curated directory of developer portfolios inspired by Emma Bostian's repository." />
    <meta property="twitter:image" content="https://images.unsplash.com/photo-1517694712202-14dd9538aa97?q=80&w=1200&auto=format&fit=crop" />

    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-N4PMFMQQ6Q"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-N4PMFMQQ6Q');
    </script>
    <!-- U1 fix: removed `.portfolio-wrapper { content-visibility: auto }`.
         Its implicit paint containment clipped the hover summary tooltip (which is
         drawn above the card). Off-screen cards are already virtualized in JS by
         toggling the `hidden` class, so the perf intent is preserved. -->
  </head>
  <body class="bg-[#0a0a0c] text-gray-200 min-h-screen font-sans antialiased selection:bg-rose-500/30">
    <style>
      .animate-hero-text {
        opacity: 0;
        animation: heroReveal 0.8s cubic-bezier(0.2, 0, 0, 1) forwards;
      }

      @keyframes heroReveal {
        0% {
          opacity: 0;
          transform: translateY(24px);
        }
        100% {
          opacity: 1;
          transform: translateY(0);
        }
      }

      .text-metallic {
        background: linear-gradient(to bottom right, #ffffff 30%, #737373 100%);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
      }
      @keyframes heartBurst {
        0% { transform: scale(1); }
        25% { transform: scale(1.5) rotate(-10deg); filter: brightness(1.5) drop-shadow(0 0 8px rgba(244,63,94,0.6)); }
        50% { transform: scale(0.85) rotate(10deg); }
        75% { transform: scale(1.15) rotate(-5deg); filter: brightness(1.2); }
        100% { transform: scale(1) rotate(0deg); }
      }

      .heart-animated {
        animation: heartBurst 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) forwards !important;
      }

      /* BUG-2 fix: each card wrapper creates its own stacking context, so a card's
         summary popup could render *under* the card sitting in the row above it.
         Lift the hovered wrapper above its neighbours so the popup (which overflows
         upward) always paints on top of everything else. */
      .portfolio-wrapper {
        position: relative;
        z-index: 1;
      }
      .portfolio-wrapper:hover,
      .portfolio-wrapper:focus-within {
        z-index: 50;
      }
    </style>

    <div class="absolute top-0 left-0 right-0 h-[650px] z-[-1] overflow-hidden pointer-events-none">
      <div class="absolute inset-0 glass-bg [mask-image:linear-gradient(to_bottom,black_60%,transparent_100%)]" style="-webkit-mask-image: linear-gradient(to bottom, black 60%, transparent 100%);"></div>
    </div>
    <div class="fixed inset-0 z-[-2] bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-[#1a1820] via-[#0a0a0c] to-[#040405]"></div>
    
    <!-- SVG filters removed for performance (PERF-1). Glass effect achieved with CSS-only backdrop-filter. -->

    <!-- Navigation Bar -->
    <nav id="topNavBar" class="sticky top-4 z-40 max-w-7xl mx-4 xl:mx-auto rounded-[24px] border border-white/[0.05]" style="transition: top 0.6s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.6s cubic-bezier(0.16, 1, 0.3, 1);">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
          <div class="flex items-center gap-2 cursor-pointer" onclick="window.scrollTo(0,0)">
            <span class="text-white font-extrabold tracking-tight text-lg flex items-center gap-1" style="font-family: 'Space Grotesk', sans-serif;">
              Portfolio
              <RotatingText
                client:load
                texts={['Universe', 'Showcase', 'Gallery', 'Directory']}
                mainClassName="text-blue-400 overflow-hidden inline-flex"
                staggerFrom="last"
                initial={{ y: "100%" }}
                animate={{ y: 0 }}
                exit={{ y: "-120%" }}
                staggerDuration={0.04}
                splitLevelClassName="overflow-hidden"
                transition={{ type: "spring", damping: 20, stiffness: 100, mass: 1.5 }}
                rotationInterval={4000}
              />
            </span>
          </div>
          
          <div class="flex items-center gap-3 md:gap-4">
            <!-- Search Bar (Desktop) -->
            <div class="relative hidden md:block w-64">
              <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gray-400"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
              </div>
              <input type="text" id="searchInputDesk" placeholder="Search developers..." class="w-full bg-gray-900 border border-gray-800 text-sm rounded-full pl-10 pr-4 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500/50 focus:border-blue-500 text-gray-200 placeholder-gray-500 transition-all" />
            </div>

            <button onclick="window.openSubmitModal()" class="text-sm font-medium text-gray-300 hover:text-white px-3 py-2 transition-colors hidden md:block">
              Submit
            </button>
            
            <!-- Auth Section -->
            <div id="authSection" class="flex items-center gap-3">
              <button onclick="window.openLoginModal()" id="loginBtn" class="bg-blue-600 hover:bg-blue-500 text-white text-sm font-semibold py-2 px-4 rounded-full shadow-lg shadow-blue-500/20 transition-all active:scale-95">
                Login
              </button>
              
              <!-- Logged In User View (Hidden by default) -->
              <div id="userProfile" class="hidden items-center gap-2 cursor-pointer group">
                <img id="userAvatar" src="" alt="Avatar" referrerpolicy="no-referrer" class="w-8 h-8 rounded-full border border-gray-700 group-hover:border-blue-500 transition-colors" />
                <span id="userName" class="text-sm font-medium text-gray-200 hidden md:block"></span>
                <button id="logoutBtn" class="text-xs text-gray-500 hover:text-red-400 ml-2 transition-colors">Logout</button>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Mobile actions: search + Submit (md:hidden) -->
        <div class="md:hidden pb-3 flex items-center gap-2">
          <div class="relative flex-1 min-w-0">
            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gray-400"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
            </div>
            <input type="text" id="searchInputMob" placeholder="Search developers..." class="w-full bg-gray-900 border border-gray-800 text-sm rounded-full pl-10 pr-4 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500/50 focus:border-blue-500 text-gray-200 placeholder-gray-500 transition-all" />
          </div>
          <button onclick="window.openSubmitModal()" aria-label="Submit a portfolio" class="shrink-0 inline-flex items-center gap-1.5 text-sm font-semibold text-white bg-white/[0.06] hover:bg-white/[0.1] border border-white/10 px-3.5 py-2 rounded-full transition-colors active:scale-95">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
            Submit
          </button>
        </div>
      </div>
    </nav>
    
    <!-- Ambient Background Effects -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none -z-10">
      <div class="absolute top-[20%] left-[20%] w-[30%] h-[30%] rounded-full bg-blue-600/20 blur-[120px] mix-blend-screen"></div>
      <div class="absolute top-[10%] right-[10%] w-[30%] h-[30%] rounded-full bg-purple-600/20 blur-[120px] mix-blend-screen"></div>
      <div class="absolute bottom-[40%] left-[20%] w-[30%] h-[30%] rounded-full bg-cyan-600/10 blur-[120px] mix-blend-screen"></div>
      
      <!-- Subtle dot grid texture (Dynamic Background Pattern) -->
      <div id="dynamic-bg-pattern" class="absolute inset-0 bg-[url('data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSIyNCIgaGVpZ2h0PSIyNCI+PGNpcmNsZSBjeD0iMSIgY3k9IjEiIHI9IjEiIGZpbGw9InJnYmEoMjU1LDI1NSwyNTUsMC4wNSkiLz48L3N2Zz4=')] [mask-image:radial-gradient(ellipse_at_center,black_20%,transparent_70%)] opacity-40 transition-all duration-1000"></div>
    </div>


    <header class="pt-10 pb-8 px-4 sm:px-6 lg:px-8 max-w-7xl mx-auto text-center relative z-10 flex flex-col items-center justify-center">
      
      <!-- Linear/Vercel Style Sharp Badge -->
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-white/10 bg-transparent text-[11px] font-semibold text-white/70 uppercase tracking-widest mb-6 animate-hero-text" style="animation-delay: 0.1s; box-shadow: 0 0 20px rgba(255,255,255,0.02);">
        <span class="w-1.5 h-1.5 rounded-full bg-sky-400 shadow-[0_0_10px_rgba(56,189,248,0.8)] animate-pulse"></span>
        Regularly Updated Showcase
      </div>
      
      <!-- Monochrome High-Tracking Brutalist Title -->
      <h1 class="text-5xl sm:text-6xl md:text-[5.5rem] font-bold mb-4 leading-[0.95] tracking-tighter flex flex-col items-center justify-center relative z-10 w-full uppercase" style="font-family: 'Space Grotesk', sans-serif;">
        <span class="text-white animate-hero-text drop-shadow-xl" style="animation-delay: 0.2s; letter-spacing: -0.04em;">The Universe</span>
        <span class="text-metallic animate-hero-text" style="animation-delay: 0.3s; letter-spacing: -0.04em;">of Creators</span>
      </h1>
      
      <!-- Minimalist Subtitle -->
      <div class="mt-5 text-[1rem] md:text-[1.1rem] text-gray-400 max-w-2xl mx-auto leading-relaxed font-normal animate-hero-text text-center" style="font-family: 'Outfit', sans-serif; animation-delay: 0.4s;">
        <VariableProximityWrapper 
          client:visible 
          count={portfolios.length} 
        />
      </div>

      <!-- Glassmorphic Filters Container -->
      <div class="mt-8 w-full md:w-max max-w-full mx-auto relative z-20 shadow-2xl border-2 border-white/20 rounded-[24px]">
        <GlassSurface client:visible width={"100%" as any} height={"auto" as any} borderRadius={24} blur={15} opacity={0.1}>
          <div class="relative flex items-center justify-start md:justify-center overflow-x-auto overflow-y-hidden hide-scrollbar gap-2 w-full p-1.5" style="-webkit-overflow-scrolling: touch;" id="filterContainer">
        
        <!-- Smooth Fluid Indicator -->
        <div id="activeIndicator" class="absolute top-0 left-0 transition-all duration-500 ease-[cubic-bezier(0.34,1.56,0.64,1)] z-0 pointer-events-none" style="width: 0px; height: 0px; transform: translate(0px, 0px);">
          <FluidGlassPill client:load />
        </div>

        <button class="filter-btn active group relative z-10 flex items-center gap-2 px-5 py-2.5 rounded-2xl text-[14px] font-medium transition-all duration-300 tracking-wide" data-filter="all">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-70 group-hover:opacity-100 transition-opacity"><rect width="7" height="7" x="3" y="3" rx="1"/><rect width="7" height="7" x="14" y="3" rx="1"/><rect width="7" height="7" x="14" y="14" rx="1"/><rect width="7" height="7" x="3" y="14" rx="1"/></svg>
          All
        </button>
        <button class="filter-btn group relative z-10 flex items-center gap-2 px-5 py-2.5 rounded-2xl text-[14px] font-medium text-purple-400 hover:text-purple-300 hover:bg-purple-500/10 transition-all duration-300 tracking-wide" data-filter="most_viewed">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:scale-110 transition-transform"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/></svg>
          Trending
        </button>
        <button class="filter-btn group relative z-10 flex items-center gap-2 px-5 py-2.5 rounded-2xl text-[14px] font-medium text-gray-400 hover:text-white hover:bg-white/[0.05] transition-all duration-300 tracking-wide" data-filter="frontend">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-70 group-hover:opacity-100 transition-opacity"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
          Frontend
        </button>
        <button class="filter-btn group relative z-10 flex items-center gap-2 px-5 py-2.5 rounded-2xl text-[14px] font-medium text-gray-400 hover:text-white hover:bg-white/[0.05] transition-all duration-300 tracking-wide" data-filter="backend">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-70 group-hover:opacity-100 transition-opacity"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>
          Backend
        </button>
        <button class="filter-btn group relative z-10 flex items-center gap-2 px-5 py-2.5 rounded-2xl text-[14px] font-medium text-gray-400 hover:text-white hover:bg-white/[0.05] transition-all duration-300 tracking-wide" data-filter="fullstack">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-70 group-hover:opacity-100 transition-opacity"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>
          Full Stack
        </button>
        <button class="filter-btn group relative z-10 flex items-center gap-2 px-5 py-2.5 rounded-2xl text-[14px] font-medium text-gray-400 hover:text-white hover:bg-white/[0.05] transition-all duration-300 tracking-wide" data-filter="designer">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-70 group-hover:opacity-100 transition-opacity"><path d="m12 19 7-7 3 3-7 7-3-3z"/><path d="m18 13-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"/><path d="m2 2 7.586 7.586"/><circle cx="11" cy="11" r="2"/></svg>
          Design
        </button>
        
        <div class="w-[2px] h-6 bg-white/[0.08] rounded-full self-center mx-2 hidden sm:block relative z-10"></div>

        <button class="filter-btn group relative z-10 flex items-center gap-2 px-5 py-2.5 rounded-2xl text-[14px] font-medium text-emerald-400 hover:text-emerald-300 hover:bg-emerald-500/10 transition-all duration-300 tracking-wide" data-filter="hire">
          <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 shadow-[0_0_8px_rgba(16,185,129,0.8)] group-hover:animate-pulse"></span>
          Hire Me
        </button>
        <button class="filter-btn group relative z-10 flex items-center gap-2 px-5 py-2.5 rounded-2xl text-[14px] font-medium text-rose-400 hover:text-rose-300 hover:bg-rose-500/10 transition-all duration-300 tracking-wide" data-filter="likes">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:scale-110 transition-transform"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
          My Likes
        </button>
          </div>
        </GlassSurface>
      </div>
    </header>

    <main class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-6 pb-24 z-10">
      <div id="portfolioGrid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 md:gap-8 items-start">
        {portfolios.slice(0, 40).map((portfolio, index) => (
          <div 
            class="portfolio-wrapper" 
            data-index={index}
            data-name={portfolio.name.toLowerCase()}
            data-url={portfolio.url}
            data-role={portfolio.role?.toLowerCase() || ''}
            data-tech={Array.isArray(portfolio.tech_stack) ? portfolio.tech_stack.join(',').toLowerCase() : ''}
            data-hire={portfolio.available_for_hire ? 'true' : 'false'}
          >
            <PortfolioCard 
              name={portfolio.name} 
              url={portfolio.url} 
              screenshot={portfolio.screenshot} 
              summary={portfolio.summary}
              role={portfolio.role}
              tech_stack={portfolio.tech_stack}
              available_for_hire={portfolio.available_for_hire}
              base_likes={portfolio.baseLikes}
              views={portfolio.views || 0}
            />
          </div>
        ))}
      </div>
      
      <!-- Empty State -->
      <div id="emptyState" class="hidden text-center py-20">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-gray-800/50 mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gray-500"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        </div>
        <h3 class="text-xl font-bold text-white mb-2">No portfolios found</h3>
        <p class="text-gray-400 text-lg">Try adjusting your search or filters.</p>
        <button id="clearFiltersBtn" class="mt-4 text-blue-400 hover:text-blue-300 font-medium">Clear all filters</button>
      </div>

      <!-- Infinite Scroll Trigger / Loader -->
      <div id="loadMoreContainer" class="mt-16 mb-8 justify-center items-center" style="display: none;">
        <div class="flex items-center gap-3 px-6 py-3 bg-gray-900/50 backdrop-blur-md rounded-full border border-gray-800">
          <svg class="animate-spin -ml-1 mr-2 h-5 w-5 text-blue-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
          <span class="text-sm font-medium text-gray-400">Loading more portfolios...</span>
        </div>
      </div>
    </main>

    <footer class="border-t border-gray-800/50 bg-gray-950/50 backdrop-blur-sm py-12 text-center text-gray-500">
      <p class="mb-4">
        Built with <a href="https://astro.build" class="text-gray-400 hover:text-white transition-colors">Astro</a>.
      </p>
      <div class="flex justify-center gap-6 text-sm">
        <a href={`${import.meta.env.BASE_URL}privacy`} class="text-gray-500 hover:text-gray-300 transition-colors">Privacy Policy</a>
        <a href={`${import.meta.env.BASE_URL}terms`} class="text-gray-500 hover:text-gray-300 transition-colors">Terms of Service</a>
      </div>
    </footer>

    <div id="toast-container" class="fixed bottom-6 right-6 z-[1000] flex flex-col gap-3 pointer-events-none"></div>

    <CustomCursor />
    <LoginModal />
    <SubmitModal />

  </body>
</html>

<style>
  .glass-bg {
    background-color: #14121a;
    background-image: url("/Portfolio-Universe/glass-texture.jpg");
    background-position: center center;
    background-size: 400px;
    opacity: 0.35;
    -webkit-animation: moveBackground 800s linear infinite;
    animation: moveBackground 800s linear infinite;
  }

  @-webkit-keyframes moveBackground {
    from { background-position: 0% 0%; }
    to { background-position: 0% -1000%; }
  }

  @keyframes moveBackground {
    from { background-position: 0% 0%; }
    to { background-position: 0% -1000%; }
  }

  #topNavBar::before {
      content: '';
      position: absolute;
      inset: 0;
      z-index: -1;
      border-radius: 24px;
      background-color: rgb(255 255 255 / 2%);
      pointer-events: none;
  }
  
  #topNavBar::after {
      content: '';
      position: absolute;
      z-index: -2;
      inset: 0;
      border-radius: 24px;
      -webkit-backdrop-filter: blur(16px) saturate(140%) brightness(1.05);
