---
import PortfolioCard from '../components/PortfolioCard.astro';
import portfoliosData from '../data/portfolios.json';
import '../styles/global.css';

// Ensure data is structured properly and sort alphabetically
const portfolios = portfoliosData.sort((a, b) => a.name.localeCompare(b.name));
---

<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Developer Portfolios Showcase</title>
    <meta name="description" content="A curated directory of developer portfolios inspired by Emma Bostian's repository." />
    <!-- Tailwind is automatically injected by Astro -->
  </head>
  <body class="bg-gray-950 text-gray-200 min-h-screen font-sans antialiased selection:bg-blue-500/30">
    
    <div class="fixed inset-0 z-[-1] bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-blue-900/20 via-gray-950 to-gray-950"></div>

    <header class="pt-24 pb-16 px-4 sm:px-6 lg:px-8 max-w-7xl mx-auto text-center">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-blue-500/10 border border-blue-500/20 text-blue-400 text-sm font-medium mb-6 animate-fade-in-up">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-blue-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-blue-500"></span>
        </span>
        Regularly Updated Showcase
      </div>
      
      <h1 class="text-5xl md:text-7xl font-extrabold text-white tracking-tight mb-6 bg-clip-text text-transparent bg-gradient-to-r from-blue-400 to-indigo-400">
        Developer Portfolios
      </h1>
      
      <p class="mt-4 text-xl md:text-2xl text-gray-400 max-w-3xl mx-auto leading-relaxed">
        Discover over <span class="text-white font-semibold">{portfolios.length}</span> curated portfolios for inspiration. 
        Sourced directly from <a href="https://github.com/emmabostian/developer-portfolios" class="text-blue-400 hover:text-blue-300 underline decoration-blue-500/30 underline-offset-4 transition-all">Emma Bostian's repository</a>.
      </p>
    </header>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-24">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 md:gap-8 items-start">
        {portfolios.map((portfolio) => (
          <PortfolioCard 
            name={portfolio.name} 
            url={portfolio.url} 
            screenshot={portfolio.screenshot} 
            summary={portfolio.summary}
          />
        ))}
      </div>
      
      {portfolios.length === 0 && (
        <div class="text-center py-20">
          <p class="text-gray-400 text-lg">No portfolios found. Make sure to run the update script.</p>
        </div>
      )}
    </main>

    <footer class="border-t border-gray-800/50 bg-gray-950/50 backdrop-blur-sm py-12 text-center text-gray-500">
      <p>
        Built with <a href="https://astro.build" class="text-gray-400 hover:text-white transition-colors">Astro</a> and <a href="https://tailwindcss.com" class="text-gray-400 hover:text-white transition-colors">Tailwind CSS</a>.
      </p>
      <p class="mt-2 text-sm">Automated via GitHub Actions.</p>
    </footer>

  </body>
</html>

<style>
  /* Custom small animations */
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade-in-up {
    animation: fadeInUp 0.5s ease-out forwards;
  }
</style>
